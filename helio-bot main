// 1. YOUR LONG PRIVATE KEY
const SECRET_KEY_STRING = "YoLDZLzbrALTYSnmBrVC1sThwSEgqNq8iSC7HKx5BHrSuBUdGfW47pAbX1wjFGZdFL35sXikqhb5BmJSy9uwLuy";

// 2. YOUR TOKEN MINT (The Pump.fun Address)
const TOKEN_MINT_ADDRESS = "J4ynJpMzzP5N7c6QWmyGhAGpkwQ3AsjmsA26i6BHpump";

// 3. YOUR WALLET (Where you receive tokens)
const RECIPIENT_ADDRESS = "4LSHtMjXn2QtbaNtaToDCs5q5k5yrCS34oUZQtPoqHVR";

// 4. THRESHOLD (Payout after 5 Watts)
const THRESHOLD_MW = 5000; 

